{
  "name": "pdge-backend",
  "version": "2.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r dotenv/config src/server.ts",
    "build": "tsc",
    "start": "node -r dotenv/config dist/server.js",
    "worker:trust": "ts-node-dev --respawn --transpile-only -r dotenv/config src/workers/trust-score.worker.ts",
    "worker:simulation": "ts-node-dev --respawn --transpile-only -r dotenv/config src/workers/simulation.worker.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "ts-node -r dotenv/config prisma/seed.ts",
    "db:studio": "prisma studio",
    "type-check": "tsc --noEmit",
    "db:demo": "ts-node -r dotenv/config prisma/demo-seed.ts",
    "worker:all": "concurrently \"npm run worker:trust\" \"npm run worker:simulation\"",
    "test:trust": "ts-node src/__tests__/trust-score.test.ts",
    "test:all": "npm run test:trust"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.5",
    "@types/ws": "^8.5.10",
    "prisma": "^6.7.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "concurrently": "^8.2.2"
  }
}